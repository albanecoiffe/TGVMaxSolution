{
  "manifest_version": 3,
  "name": "SNCF Connect Probe",
  "version": "0.1.0",
  "description": "Observe les appels reseau de SNCF Connect depuis une session navigateur reelle.",
  "permissions": [
    "storage",
    "downloads",
    "alarms",
    "notifications",
    "tabs"
  ],
  "host_permissions": [
    "https://www.sncf-connect.com/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.sncf-connect.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "injected.js"
      ],
      "matches": [
        "https://www.sncf-connect.com/*"
      ]
    }
  ],
  "action": {
    "default_title": "SNCF Connect Probe",
    "default_popup": "popup.html"
  }
}
